<?php
declare(strict_types=1);
/** @var FreshRSS_View $this */
$ext = $this->extension;
?>
<form method="post" action="<?php echo _url('extension', 'configure', 'e', urlencode($ext->getName())); ?>">
	<div class="form-group">
		<label class="group-name" for="ssml">SSML</label>
		<div class="group-controls">
			<label class="checkbox" for="ssml">
				<input type="checkbox" name="ssml" id="ssml" value="1"
					<?php echo $ext->getUserConfigurationValue('ssml', false) ? 'checked' : ''; ?> />
				Build SSML markup (emphasis / breaks / prosody). Apple voices on
				Safari/macOS honour it; Google voices read the tags out loud, so
				leave this off for them.
			</label>
		</div>
	</div>

	<div class="form-group">
		<label class="group-name" for="languages">Voice languages</label>
		<div class="group-controls">
			<textarea name="languages" id="languages" rows="5" cols="30"
				placeholder="es-ES&#10;es-US&#10;en-GB"><?php
				echo htmlspecialchars(
					$ext->getUserConfigurationValue('languages', ''),
					ENT_QUOTES,
					'UTF-8'
				);
			?></textarea>
			<p class="help">
				<span class="icon"><img class="icon" src="<?php echo Minz_Url::display('/themes/icons/help.svg'); ?>" alt="help" /></span>
				One language tag per line (e.g. <code>es-ES</code>, <code>es-US</code>)
				to only list voices for those languages. A bare tag like
				<code>es</code> matches every <code>es-*</code> variant. Leave
				empty to show all voices.
			</p>
		</div>
	</div>

	<div class="form-group form-actions">
		<div class="group-controls">
			<button type="submit" class="btn btn-important"><?php echo _t('gen.action.submit'); ?></button>
		</div>
	</div>

	<input type="hidden" name="_csrf" value="<?php echo FreshRSS_Auth::csrfToken(); ?>" />
</form>
